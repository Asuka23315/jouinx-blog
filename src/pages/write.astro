---
import MainGridLayout from "../layouts/MainGridLayout.astro";

// 仅开发模式下可写。生产环境应该走 /admin Sveltia CMS（需配 OAuth）
const isDev = import.meta.env.DEV;
---

<MainGridLayout title="写作">
    <div class="card-base p-6 md:p-8">
        {!isDev && (
            <div class="rounded-lg border border-yellow-500/30 bg-yellow-500/10 px-4 py-3 mb-4">
                <p class="text-yellow-200/90 text-sm m-0">
                    ⚠️ 内置编辑器仅在本地开发模式下能保存。
                    部署上线后请使用 <a href="/admin/" class="underline">/admin</a>（Sveltia CMS）。
                </p>
            </div>
        )}

        <h1 class="font-bold text-2xl md:text-3xl text-black/90 dark:text-white/90 mb-6">写一篇</h1>

        <form id="write-form" class="space-y-5">
            <!-- 标题 -->
            <div>
                <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">标题</label>
                <input
                    id="f-title"
                    type="text"
                    placeholder="如水如雨"
                    required
                    class="mt-1 w-full bg-transparent border-b border-black/15 dark:border-white/15 pb-2 text-2xl md:text-3xl font-bold text-black/90 dark:text-white/90 focus:outline-none focus:border-[var(--primary)] transition-colors"
                />
            </div>

            <!-- 元信息 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">slug（URL 路径，留空自动从标题生成）</label>
                    <input
                        id="f-slug"
                        type="text"
                        placeholder="like-water-like-rain"
                        class="mt-1 w-full input-pill"
                    />
                </div>
                <div>
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">发布日期</label>
                    <input
                        id="f-published"
                        type="date"
                        class="mt-1 w-full input-pill"
                    />
                </div>
                <div>
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">分类</label>
                    <input
                        id="f-category"
                        type="text"
                        placeholder="拉康笔记 / 文学随笔 / 游戏感想 ..."
                        class="mt-1 w-full input-pill"
                    />
                </div>
                <div>
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">标签（逗号分隔）</label>
                    <input
                        id="f-tags"
                        type="text"
                        placeholder="拉康, 享乐, 主体"
                        class="mt-1 w-full input-pill"
                    />
                </div>
            </div>

            <!-- 摘要 + 草稿 -->
            <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-start">
                <div>
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">摘要（一两句，列表里显示）</label>
                    <textarea
                        id="f-description"
                        rows="2"
                        placeholder=""
                        class="mt-1 w-full input-pill !rounded-lg"
                    ></textarea>
                </div>
                <label class="mt-6 inline-flex items-center gap-2 cursor-pointer select-none">
                    <input id="f-draft" type="checkbox" class="w-4 h-4 accent-[var(--primary)]" />
                    <span class="text-sm text-black/70 dark:text-white/70">草稿</span>
                </label>
            </div>

            <!-- 编辑器 + 预览 -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <label class="text-xs uppercase tracking-widest text-black/50 dark:text-white/50">正文（Markdown）</label>
                    <div class="flex gap-2">
                        <button type="button" id="toggle-preview" class="text-xs px-3 py-1 rounded-full border border-black/15 dark:border-white/15 hover:bg-black/5 dark:hover:bg-white/5 transition">
                            切换预览
                        </button>
                    </div>
                </div>
                <div id="editor-grid" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <textarea
                        id="f-body"
                        rows="22"
                        placeholder="# 副标题&#10;&#10;在这里写..."
                        class="font-mono text-sm leading-7 bg-black/5 dark:bg-black/30 border border-black/10 dark:border-white/10 rounded-lg p-4 focus:outline-none focus:border-[var(--primary)]/60 transition-colors text-black/90 dark:text-white/90 resize-none"
                    ></textarea>
                    <div
                        id="preview"
                        class="bg-black/5 dark:bg-black/30 border border-black/10 dark:border-white/10 rounded-lg p-4 overflow-auto prose prose-invert prose-sm max-w-none"
                    >
                        <p class="text-black/40 dark:text-white/40 italic">预览将出现在这里…</p>
                    </div>
                </div>
            </div>

            <!-- 操作 -->
            <div class="flex items-center justify-between gap-3 pt-2">
                <p id="status" class="text-sm text-black/50 dark:text-white/50 m-0"></p>
                <div class="flex gap-3">
                    <button type="button" id="save-draft" class="px-5 py-2 rounded-lg border border-black/15 dark:border-white/15 hover:bg-black/5 dark:hover:bg-white/5 transition text-sm">
                        保存为草稿
                    </button>
                    <button type="submit" id="publish" class="px-5 py-2 rounded-lg bg-[var(--primary)] text-white dark:text-black/85 font-bold hover:opacity-90 transition text-sm">
                        发布
                    </button>
                </div>
            </div>
        </form>
    </div>
</MainGridLayout>

<style>
    .input-pill {
        background: rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 9999px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        color: inherit;
        transition: border-color 0.2s, background 0.2s;
        display: block;
        width: 100%;
        box-sizing: border-box;
    }
    :global(.dark) .input-pill {
        background: rgba(0, 0, 0, 0.3);
        border-color: rgba(255, 255, 255, 0.1);
    }
    .input-pill:focus {
        outline: none;
        border-color: var(--primary);
    }
    textarea.input-pill {
        border-radius: 0.5rem;
        font-family: inherit;
        resize: vertical;
    }
    /* 预览区的 markdown 样式（简易 prose） */
    #preview h1, #preview h2, #preview h3, #preview h4 {
        color: rgba(255, 255, 255, 0.92);
        font-weight: 700;
        margin: 1em 0 0.5em;
        line-height: 1.3;
    }
    #preview h1 { font-size: 1.6rem; }
    #preview h2 { font-size: 1.35rem; }
    #preview h3 { font-size: 1.15rem; }
    #preview p { margin: 0.6em 0; line-height: 1.7; }
    #preview a { color: var(--primary); text-decoration: underline; }
    #preview blockquote {
        border-left: 3px solid var(--primary);
        padding-left: 1em;
        color: rgba(255, 255, 255, 0.6);
        font-style: italic;
        margin: 0.8em 0;
    }
    #preview code {
        background: rgba(255, 255, 255, 0.08);
        padding: 0.1em 0.35em;
        border-radius: 3px;
        font-size: 0.85em;
    }
    #preview pre {
        background: rgba(0, 0, 0, 0.3);
        padding: 0.8em;
        border-radius: 6px;
        overflow-x: auto;
    }
    #preview pre code { background: transparent; padding: 0; }
    #preview ul, #preview ol { padding-left: 1.5em; margin: 0.6em 0; }
    #preview li { margin: 0.2em 0; }
    #preview hr { border-color: rgba(255, 255, 255, 0.1); margin: 1.5em 0; }
    #preview img { max-width: 100%; border-radius: 6px; }
</style>

<script>
    import { marked } from "marked";

    const $title = document.getElementById("f-title") as HTMLInputElement;
    const $slug = document.getElementById("f-slug") as HTMLInputElement;
    const $published = document.getElementById("f-published") as HTMLInputElement;
    const $category = document.getElementById("f-category") as HTMLInputElement;
    const $tags = document.getElementById("f-tags") as HTMLInputElement;
    const $description = document.getElementById("f-description") as HTMLTextAreaElement;
    const $draft = document.getElementById("f-draft") as HTMLInputElement;
    const $body = document.getElementById("f-body") as HTMLTextAreaElement;
    const $preview = document.getElementById("preview") as HTMLElement;
    const $status = document.getElementById("status") as HTMLElement;
    const $form = document.getElementById("write-form") as HTMLFormElement;
    const $togglePreview = document.getElementById("toggle-preview") as HTMLButtonElement;
    const $editorGrid = document.getElementById("editor-grid") as HTMLElement;
    const $saveDraft = document.getElementById("save-draft") as HTMLButtonElement;

    // 默认填今天
    const today = new Date().toISOString().slice(0, 10);
    if (!$published.value) $published.value = today;

    // 自动 slug：标题改变时，如果 slug 为空，根据标题自动生成
    function slugify(input: string) {
        return input
            .trim()
            .toLowerCase()
            .replace(/[\s　]+/g, "-")
            .replace(/[^a-z0-9一-龥\-_]/g, "")
            .replace(/-+/g, "-")
            .replace(/^-|-$/g, "");
    }
    let slugTouched = false;
    $slug.addEventListener("input", () => { slugTouched = true; });
    $title.addEventListener("input", () => {
        if (!slugTouched) $slug.value = slugify($title.value);
    });

    // 实时预览（防抖）
    let previewTimer: number | undefined;
    function updatePreview() {
        const md = $body.value;
        if (md.trim() === "") {
            $preview.innerHTML = '<p class="text-black/40 dark:text-white/40 italic">预览将出现在这里…</p>';
            return;
        }
        try {
            const html = marked.parse(md, { breaks: true, async: false }) as string;
            $preview.innerHTML = html;
        } catch (e) {
            $preview.innerHTML = `<pre>渲染错误: ${String(e)}</pre>`;
        }
    }
    $body.addEventListener("input", () => {
        clearTimeout(previewTimer);
        previewTimer = window.setTimeout(updatePreview, 120);
    });

    // 切换预览（隐藏右侧预览）
    let previewHidden = false;
    $togglePreview.addEventListener("click", () => {
        previewHidden = !previewHidden;
        if (previewHidden) {
            $preview.style.display = "none";
            $editorGrid.style.gridTemplateColumns = "1fr";
        } else {
            $preview.style.display = "";
            $editorGrid.style.gridTemplateColumns = "";
        }
    });

    // 本地草稿持久化（防止刷新丢失）
    const DRAFT_KEY = "jouinx-write-draft";
    function loadDraft() {
        try {
            const raw = localStorage.getItem(DRAFT_KEY);
            if (!raw) return;
            const d = JSON.parse(raw);
            if (d.title) $title.value = d.title;
            if (d.slug) { $slug.value = d.slug; slugTouched = true; }
            if (d.published) $published.value = d.published;
            if (d.category) $category.value = d.category;
            if (d.tags) $tags.value = d.tags;
            if (d.description) $description.value = d.description;
            if (typeof d.draft === "boolean") $draft.checked = d.draft;
            if (d.body) $body.value = d.body;
            updatePreview();
        } catch (e) {}
    }
    function saveLocalDraft() {
        const data = {
            title: $title.value,
            slug: $slug.value,
            published: $published.value,
            category: $category.value,
            tags: $tags.value,
            description: $description.value,
            draft: $draft.checked,
            body: $body.value,
        };
        try {
            localStorage.setItem(DRAFT_KEY, JSON.stringify(data));
        } catch (e) {}
    }
    function clearLocalDraft() {
        try { localStorage.removeItem(DRAFT_KEY); } catch (e) {}
    }
    loadDraft();

    // 每次输入自动存到 localStorage
    [$title, $slug, $published, $category, $tags, $description, $body].forEach((el) => {
        el.addEventListener("input", saveLocalDraft);
    });
    $draft.addEventListener("change", saveLocalDraft);

    // 收集表单数据
    function collectFormData(forceDraft = false) {
        const tagList = $tags.value
            .split(/[,，]/)
            .map((s) => s.trim())
            .filter((s) => s.length > 0);
        return {
            title: $title.value.trim(),
            slug: $slug.value.trim() || slugify($title.value),
            published: $published.value || today,
            description: $description.value.trim(),
            tags: tagList,
            category: $category.value.trim(),
            draft: forceDraft ? true : $draft.checked,
            body: $body.value,
        };
    }

    async function submit(payload: ReturnType<typeof collectFormData>, label: string) {
        $status.textContent = `正在${label}…`;
        $status.style.color = "";
        try {
            const res = await fetch("/api/save-post/", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });
            const json = await res.json();
            if (!res.ok) {
                throw new Error(json.error || `HTTP ${res.status}`);
            }
            $status.textContent = `已${label} → ${json.slug}.md`;
            $status.style.color = "rgb(134, 239, 172)";
            clearLocalDraft();
            // 跳到新文章
            if (!payload.draft) {
                setTimeout(() => {
                    window.location.href = `/posts/${json.slug}/`;
                }, 800);
            }
        } catch (e) {
            $status.textContent = `失败：${e instanceof Error ? e.message : String(e)}`;
            $status.style.color = "rgb(252, 165, 165)";
        }
    }

    $form.addEventListener("submit", (e) => {
        e.preventDefault();
        const data = collectFormData();
        if (!data.title) { $status.textContent = "标题不能空"; return; }
        if (!data.body.trim()) { $status.textContent = "正文不能空"; return; }
        submit(data, "发布");
    });

    $saveDraft.addEventListener("click", () => {
        const data = collectFormData(true);
        if (!data.title) { $status.textContent = "标题不能空"; return; }
        submit(data, "保存草稿");
    });
</script>
